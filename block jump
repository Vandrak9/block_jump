#include <furi.h>
#include <furi_hal.h>
#include <gui/gui.h>
#include <input/input.h>
#include <stdlib.h>
#include <stdio.h>

#define GROUND_Y 58
#define PLAYER_X 12
#define PLAYER_SIZE 8
#define OBSTACLE_SIZE 6
#define TICK_MS 33

typedef enum {
    GameStateRunning,
    GameStateOver,
} GameState;

typedef struct {
    int player_y;
    int velocity;
    bool on_ground;
    int obstacle_x;
    int score;
    int speed;
    GameState state;
    FuriMutex* mutex;
} GameContext;

static void play_tone(float freq, uint32_t duration_ms) {
    if(furi_hal_speaker_acquire(30)) {
        furi_hal_speaker_start(freq, 1.0f);
        furi_delay_ms(duration_ms);
        furi_hal_speaker_stop();
        furi_hal_speaker_release();
    }
}

static void reset_game(GameContext* game) {
    game->player_y = GROUND_Y - PLAYER_SIZE;
    game->velocity = 0;
    game->on_ground = true;
    game->obstacle_x = 128;
    game->score = 0;
    game->speed = 3;
    game->state = GameStateRunning;
}

static void draw_callback(Canvas* canvas, void* ctx) {
    GameContext* game = ctx;
    furi_mutex_acquire(game->mutex, FuriWaitForever);

    canvas_clear(canvas);
    canvas_set_color(canvas, ColorBlack);

    // ground line
    canvas_draw_line(canvas, 0, GROUND_Y, 128, GROUND_Y);

    // player: body block + small "cap" on top (original sprite, not a licensed character)
    canvas_draw_box(canvas, PLAYER_X, game->player_y, PLAYER_SIZE, PLAYER_SIZE);
    canvas_draw_box(canvas, PLAYER_X - 1, game->player_y - 2, PLAYER_SIZE + 2, 2);

    // obstacle block
    if(game->state == GameStateRunning) {
        canvas_draw_box(
            canvas, game->obstacle_x, GROUND_Y - OBSTACLE_SIZE, OBSTACLE_SIZE, OBSTACLE_SIZE);
    }

    char buf[24];
    snprintf(buf, sizeof(buf), "Score: %d", game->score);
    canvas_draw_str(canvas, 2, 10, buf);

    if(game->state == GameStateOver) {
        canvas_draw_str(canvas, 36, 30, "GAME OVER");
        canvas_draw_str(canvas, 22, 42, "OK = restart");
    }

    furi_mutex_release(game->mutex);
}

static void input_callback(InputEvent* input_event, void* ctx) {
    FuriMessageQueue* queue = ctx;
    furi_message_queue_put(queue, input_event, FuriWaitForever);
}

static void timer_callback(void* ctx) {
    GameContext* game = ctx;
    furi_mutex_acquire(game->mutex, FuriWaitForever);

    if(game->state == GameStateRunning) {
        // gravity / jump physics
        if(!game->on_ground) {
            game->velocity += 1;
            game->player_y += game->velocity;
            if(game->player_y >= GROUND_Y - PLAYER_SIZE) {
                game->player_y = GROUND_Y - PLAYER_SIZE;
                game->velocity = 0;
                game->on_ground = true;
            }
        }

        // move obstacle towards player
        game->obstacle_x -= game->speed;
        if(game->obstacle_x < -OBSTACLE_SIZE) {
            game->obstacle_x = 128 + (rand() % 40);
            game->score++;
            if(game->score % 5 == 0 && game->speed < 8) game->speed++;
        }

        // collision check
        bool overlap_x = (game->obstacle_x < PLAYER_X + PLAYER_SIZE) &&
                          (game->obstacle_x + OBSTACLE_SIZE > PLAYER_X);
        bool overlap_y = (game->player_y + PLAYER_SIZE) > (GROUND_Y - OBSTACLE_SIZE);
        if(overlap_x && overlap_y) {
            game->state = GameStateOver;
        }
    }

    furi_mutex_release(game->mutex);
}

int32_t block_jump_app(void* p) {
    UNUSED(p);

    GameContext* game = malloc(sizeof(GameContext));
    game->mutex = furi_mutex_alloc(FuriMutexTypeNormal);
    reset_game(game);

    FuriMessageQueue* event_queue = furi_message_queue_alloc(8, sizeof(InputEvent));

    ViewPort* view_port = view_port_alloc();
    view_port_draw_callback_set(view_port, draw_callback, game);
    view_port_input_callback_set(view_port, input_callback, event_queue);

    Gui* gui = furi_record_open(RECORD_GUI);
    gui_add_view_port(gui, view_port, GuiLayerFullscreen);

    FuriTimer* timer = furi_timer_alloc(timer_callback, FuriTimerTypePeriodic, game);
    furi_timer_start(timer, furi_ms_to_ticks(TICK_MS));

    InputEvent event;
    bool running = true;
    int last_score = 0;
    GameState last_state = GameStateRunning;

    while(running) {
        FuriStatus status = furi_message_queue_get(event_queue, &event, 100);

        if(status == FuriStatusOk) {
            if(event.type == InputTypeShort || event.type == InputTypeRepeat) {
                furi_mutex_acquire(game->mutex, FuriWaitForever);
                switch(event.key) {
                case InputKeyBack:
                    running = false;
                    break;
                case InputKeyUp:
                case InputKeyOk:
                    if(game->state == GameStateRunning && game->on_ground) {
                        game->on_ground = false;
                        game->velocity = -7;
                    } else if(game->state == GameStateOver) {
                        reset_game(game);
                        last_score = 0;
                        last_state = GameStateRunning;
                    }
                    break;
                default:
                    break;
                }
                furi_mutex_release(game->mutex);

                if(event.key == InputKeyUp || event.key == InputKeyOk) {
                    play_tone(800.0f, 30);
                }
            }
        }

        // poll state for sound effects (kept outside the timer callback on purpose)
        furi_mutex_acquire(game->mutex, FuriWaitForever);
        int cur_score = game->score;
        GameState cur_state = game->state;
        furi_mutex_release(game->mutex);

        if(cur_score != last_score) {
            play_tone(1200.0f, 20);
            last_score = cur_score;
        }
        if(cur_state == GameStateOver && last_state != GameStateOver) {
            play_tone(180.0f, 200);
        }
        last_state = cur_state;

        view_port_update(view_port);
    }

    furi_timer_free(timer);
    gui_remove_view_port(gui, view_port);
    furi_record_close(RECORD_GUI);
    view_port_free(view_port);
    furi_message_queue_free(event_queue);
    furi_mutex_free(game->mutex);
    free(game);

return 0;
}
